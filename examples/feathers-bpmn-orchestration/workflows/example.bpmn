<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:meta="http://kalisio.com/bpmn/meta"
             targetNamespace="http://kalisio.com/bpmn"
             id="feathers-bpmn-orchestration">

  <process id="orchestration-process" isExecutable="true">

    <!-- Start -->
    <startEvent id="start" name="Start" />
    <sequenceFlow id="flow-start-ingest" sourceRef="start" targetRef="task-ingest" />

    <!--
      Step 1 — Docker worker (ephemeral container created by dockerode)
    -->
    <serviceTask id="task-ingest" name="Ingest data">
      <extensionElements>
        <meta:jobType>docker-job</meta:jobType>
        <meta:steps>3</meta:steps>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow-ingest-split" sourceRef="task-ingest" targetRef="gateway-split" />

    <!-- Parallel split: two K8s tasks run simultaneously -->
    <parallelGateway id="gateway-split" name="Split" />
    <sequenceFlow id="flow-split-processA" sourceRef="gateway-split" targetRef="task-processA" />
    <sequenceFlow id="flow-split-processB" sourceRef="gateway-split" targetRef="task-processB" />

    <!--
      Step 2a — K8s worker (ephemeral Pod created by the K8s API client)
    -->
    <serviceTask id="task-processA" name="Process A (model inference)">
      <extensionElements>
        <meta:jobType>k8s-job</meta:jobType>
        <meta:steps>4</meta:steps>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow-processA-join" sourceRef="task-processA" targetRef="gateway-join" />

    <!--
      Step 2b — K8s worker
    -->
    <serviceTask id="task-processB" name="Process B (data transform)">
      <extensionElements>
        <meta:jobType>k8s-job</meta:jobType>
        <meta:steps>2</meta:steps>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow-processB-join" sourceRef="task-processB" targetRef="gateway-join" />

    <!-- Parallel join -->
    <parallelGateway id="gateway-join" name="Join" />
    <sequenceFlow id="flow-join-export" sourceRef="gateway-join" targetRef="task-export" />

    <!--
      Step 3 — Docker worker
    -->
    <serviceTask id="task-export" name="Export result">
      <extensionElements>
        <meta:jobType>docker-job</meta:jobType>
        <meta:steps>2</meta:steps>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow-export-end" sourceRef="task-export" targetRef="end" />

    <!-- End -->
    <endEvent id="end" name="End" />

  </process>

</definitions>
