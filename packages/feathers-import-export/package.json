{
  "name": "@kalisio/feathers-import-export",
  "description": "Import / Export data with FeathersJS",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "standard": {
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "standard --fix",
    "pretest": "pnpm --filter @kalisio/feathers-s3 build",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/feathers-ekosystem.git",
    "directory": "packages/feathers-import-export"
  },
  "bugs": {
    "url": "https://github.com/kalisio/feathers-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/feathers-ekosystem/tree/main/packages/feathers-import-export",
  "dependencies": {
    "@kalisio/common-core": "catalog:",
    "@kalisio/feathers-s3": "workspace:",
    "JSONStream": "^1.3.5",
    "archiver": "catalog:",
    "debug": "catalog:",
    "lodash": "catalog:",
    "papaparse": "catalog:"
  },
  "devDependencies": {
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/mongodb": "catalog:",
    "mongodb": "catalog:",
    "tar": "catalog:",
    "unzipper": "catalog:"
  }
}
