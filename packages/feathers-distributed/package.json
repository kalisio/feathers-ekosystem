{
  "name": "@kalisio/feathers-distributed",
  "description": "Distribute your Feathers services as microservices",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "standard": {
    "globals": [
      "describe",
      "it",
      "expect",
      "beforeEach",
      "afterEach"
    ],
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "standard ",
    "lint:fix": "standard --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/feathers-ekosystem.git",
    "directory": "packages/feathers-distributed"
  },
  "bugs": {
    "url": "https://github.com/kalisio/feathers-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/feathers-ekosystem/tree/main/packages/feathers-distributed",
  "dependencies": {
    "@feathersjs/commons": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "cote": "^1.0.3",
    "debug": "catalog:",
    "portfinder": "^1.0.25",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/authentication-client": "catalog:",
    "@feathersjs/authentication-local": "catalog:",
    "@feathersjs/rest-client": "catalog:",
    "@feathersjs/socketio-client": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/memory": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "feathers-hooks-common": "catalog:",
    "mongodb": "catalog:",
    "socket.io-client": "catalog:",
    "superagent": "catalog:"
  }
}
