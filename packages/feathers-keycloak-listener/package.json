{
  "name": "@kalisio/feathers-keycloak-listener",
  "description": "Bridge Keycloak authentication events into your FeathersJS application",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "standard": {
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "standard --fix",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "feathersjs",
    "feathers",
    "keycloak",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/feathers-ekosystem.git",
    "directory": "packages/feathers-keycloak-listener"
  },
  "bugs": {
    "url": "https://github.com/kalisio/feathers-ekosystem/issues"
  },
  "homepage": "https://kalisio.github.io/feathers-ekosystem/packages/feathers-keycloak-listener",
  "dependencies": {
    "@feathersjs/errors": "catalog:",
    "debug": "catalog:",
    "lodash": "catalog:"
  },
  "devDependencies": {
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/memory": "catalog:"
  }
}