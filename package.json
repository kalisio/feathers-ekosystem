{
  "name": "feathers-ekosystem",
  "description": "A collection of modules for FeathersJS",
  "packageManager": "pnpm@10.1.0",
  "type": "module",
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "pnpm lint"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:feathers-distributed": "pnpm --filter @kalisio/feathers-distributed build",
    "build:feathers-import-export": "pnpm --filter @kalisio/feathers-import-export build",
    "build:feathers-keycloak-listener": "pnpm --filter @kalisio/feathers-keycloak-listener build",
    "build:feathers-mongodb-management": "pnpm --filter @kalisio/feathers-mongodb-management build",
    "build:feathers-s3": "pnpm --filter @kalisio/feathers-s3 build",
    "build:feathers-webpush": "pnpm --filter @kalisio/feathers-webpush build",
    "changeset": "changeset",
    "changeset:release": "pnpm build && changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "lint": "pnpm -r lint --fix",
    "lint:feathers-distributed": "pnpm --filter @kalisio/feathers-distributed lint --fix",
    "lint:feathers-import-export": "pnpm --filter @kalisio/feathers-import-export lint --fix",
    "lint:feathers-keycloak-listener": "pnpm --filter @kalisio/feathers-keycloak-listener lint --fix",
    "lint:feathers-mongodb-management": "pnpm --filter @kalisio/feathers-mongodb-management lint --fix",
    "lint:feathers-s3": "pnpm --filter @kalisio/feathers-s3 lint --fix",
    "lint:feathers-webpush": "pnpm --filter @kalisio/feathers-webpush lint --fix",
    "prepare": "husky",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r test --coverage",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info",
    "test:feathers-distributed": "pnpm --filter @kalisio/feathers-distributed test --coverage",
    "test:feathers-import-export": "pnpm --filter @kalisio/feathers-import-export test --coverage",
    "test:feathers-keycloak-listener": "pnpm --filter @kalisio/feathers-keycloak-listener test --coverage",
    "test:feathers-mongodb-management": "pnpm --filter @kalisio/feathers-mongodb-management test --coverage",
    "test:feathers-s3": "pnpm --filter @kalisio/feathers-s3 test --coverage",
    "test:feathers-webpush": "pnpm --filter @kalisio/feathers-webpush test --coverage"
  },
  "keywords": [
    "keycloak",
    "web-push",
    "feathers",
    "ekosystem",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/feathers-ekosystem.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/feathers-ekosystem/issues"
  },
  "homepage": "https://kalisio.github.io/feathers-ekosystem/",
  "dependencies": {
    "keycloak-js": "catalog:",
    "lodash": "catalog:",
    "moment": "catalog:",
    "quasar": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@kalisio/meta-ekosystem": "^0.6.0",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "husky": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "mermaid": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:",
    "vitepress": "catalog:",
    "vitepress-plugin-mermaid": "catalog:",
    "vitepress-theme-kalisio": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {}
  },
  "metaCatalog": "0.7.0"
}